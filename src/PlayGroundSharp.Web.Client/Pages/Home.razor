@page "/"
@implements IAsyncDisposable
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>PlayGroundSharp Web</PageTitle>

<header class="topbar">
    <div class="brand">
        <div class="brand-mark">C#</div>
        <div>
            <h1>PlayGroundSharp <span>Web</span></h1>
            <p>Blazor WebAssembly preview</p>
        </div>
    </div>
    <div class="topbar-actions">
        <span class="status-pill @StatusClass"><span></span>@status</span>
        <button class="ghost-button" @onclick="SaveWorkspaceAsync" disabled="@isBusy">保存</button>
        <button class="ghost-button" @onclick="ResetAsync" disabled="@isBusy">リセット</button>
    </div>
</header>

<div class="preview-notice">
    <strong>ローカルWasmプレビュー</strong>
    UIと入力支援はブラウザーで動作し、Roslyn解析とC#実行はローカルの分離Workerへ送られます。
</div>

<main class="workspace">
    <section class="primary-column">
        <div class="panel editor-panel">
            <div class="panel-heading">
                <div>
                    <span class="eyebrow">SUBMISSION @(submissionIndex + 1)</span>
                    <h2>C#を入力</h2>
                </div>
                <div class="key-help"><kbd>Tab</kbd> 補完 <kbd>Enter</kbd> 実行 <kbd>Shift</kbd>＋<kbd>Enter</kbd> 改行</div>
            </div>
            <div class="editor-host">
                <textarea class="code-editor" value="@(code)" @oninput="HandleEditorInputAsync" @ref="editor" @onkeydown="HandleEditorKeyDownAsync"
                          spellcheck="false" aria-label="C# code editor"></textarea>
                @if (completions.Count > 0)
                {
                    <div class="completion-popup">
                        <div class="completion-items">
                            @for (var index = 0; index < completions.Count; index++)
                            {
                                var itemIndex = index;
                                var item = completions[index];
                                <button class="completion-item @(itemIndex == selectedCompletion ? "selected" : null)"
                                        @onclick="() => SelectAndAcceptCompletionAsync(itemIndex)">
                                    <span class="completion-icon">@(item.IsExtensionMethod ? "ext" : CompletionIcon(item))</span>
                                    <span class="completion-name">@item.DisplayText</span>
                                    @if (!string.IsNullOrWhiteSpace(item.NamespaceHint))
                                    {
                                        <span class="completion-namespace">@item.NamespaceHint</span>
                                    }
                                </button>
                            }
                        </div>
                        <div class="completion-detail">
                            <strong>@SelectedCompletion?.DisplayText</strong>
                            @if (!string.IsNullOrWhiteSpace(SelectedCompletion?.NamespaceHint))
                            {
                                <code>@SelectedCompletion!.NamespaceHint</code>
                            }
                            <p>@(completionDescription ?? "候補を選ぶとシグネチャとSummaryを表示します。")</p>
                        </div>
                    </div>
                }
                @if (signatureHelp is { Signatures.Count: > 0 })
                {
                    var signature = signatureHelp.Signatures[selectedSignature];
                    <div class="signature-popup">
                        <div class="signature-toolbar">
                            <span>@(selectedSignature + 1) / @signatureHelp.Signatures.Count</span>
                            <button @onclick="() => ChangeSignature(-1)">‹</button>
                            <button @onclick="() => ChangeSignature(1)">›</button>
                        </div>
                        <code>@signature.DisplayText</code>
                        @if (signature.Parameters.Count > signature.ActiveParameter)
                        {
                            var parameter = signature.Parameters[signature.ActiveParameter];
                            <p><strong>@parameter.Name</strong> <span>@parameter.TypeName</span> @parameter.Summary</p>
                        }
                        @if (!string.IsNullOrWhiteSpace(signature.Summary))
                        {
                            <p>@signature.Summary</p>
                        }
                    </div>
                }
            </div>
            <div class="editor-footer">
                <span>@LineCount 行</span>
                <button class="run-button" @onclick="ExecuteAsync" disabled="@(isBusy || string.IsNullOrWhiteSpace(code))">
                    @if (isBusy)
                    {
                        <span class="spinner"></span><span>処理中</span>
                    }
                    else
                    {
                        <span>実行</span><span class="run-icon">↵</span>
                    }
                </button>
            </div>
        </div>

        <section class="history-section">
            <div class="section-title">
                <div><span class="eyebrow">OUTPUT</span><h2>実行結果</h2></div>
                @if (history.Count > 0)
                {
                    <button class="text-button" @onclick="ClearHistory">表示をクリア</button>
                }
            </div>

            @if (history.Count == 0)
            {
                <div class="empty-output">
                    <div class="empty-icon">{ }</div>
                    <strong>まだ実行結果はありません</strong>
                    <span>例: <code>Enumerable.Range(1, 5).Select(x =&gt; new { x, square = x * x }).ToArray()</code></span>
                </div>
            }
            else
            {
                @foreach (var item in history.AsEnumerable().Reverse())
                {
                    <article class="submission-card" @key="item.Index">
                        <div class="submission-code">
                            <span>#@item.Index</span><pre>@item.Code</pre>
                            <button class="copy-button" title="入力と結果をコピー" @onclick="() => CopyAsync(item)">コピー</button>
                        </div>
                        <div class="submission-result">
                            @if (item.StandardOutput.Count > 0)
                            {
                                <pre class="console-output">@string.Concat(item.StandardOutput)</pre>
                            }
                            @foreach (var diagnostic in item.Diagnostics)
                            {
                                <div class="diagnostic diagnostic-@diagnostic.Level.ToString().ToLowerInvariant()">
                                    <strong>@diagnostic.Id</strong><span>@diagnostic.Message</span><small>@diagnostic.StartLine:@diagnostic.StartColumn</small>
                                </div>
                            }
                            @if (item.DiagnosticTotalCount > item.Diagnostics.Count)
                            {
                                <div class="diagnostic diagnostic-warning">
                                    <strong>省略</strong><span>全@item.DiagnosticTotalCount 件のうち先頭@item.Diagnostics.Count 件を表示しています。</span>
                                </div>
                            }
                            @if (item.Error is not null)
                            {
                                <div class="runtime-error"><strong>@item.Error.TypeName</strong><span>@item.Error.Message</span></div>
                            }
                            @if (item.Result is not null)
                            {
                                <div class="result-header"><span>result</span><code>@DisplayType(item.Result)</code></div>
                                <SnapshotView Snapshot="item.Result" />
                            }
                            @if (item.Result is null && item.Diagnostics.Count == 0 && item.Error is null && item.StandardOutput.Count == 0)
                            {
                                <span class="void-result">実行完了（戻り値なし）</span>
                            }
                        </div>
                    </article>
                }
            }
        </section>
    </section>

    <aside class="side-column">
        <section class="panel side-panel">
            <div class="side-heading"><div><span class="eyebrow">SESSION</span><h2>変数</h2></div><span class="count-badge">@variables.Count</span></div>
            @if (variables.Count == 0)
            {
                <p class="side-empty">実行後の変数がここに表示されます。</p>
            }
            else
            {
                <div class="variable-list">
                    @foreach (var variable in variables)
                    {
                        <details class="variable-item" @key="variable.Name">
                            <summary><code>@variable.Name</code><span>@ShortTypeName(variable.TypeName)</span></summary>
                            <SnapshotView Snapshot="variable.Value" />
                        </details>
                    }
                </div>
            }
        </section>

        <section class="panel side-panel">
            <div class="side-heading"><div><span class="eyebrow">DEPENDENCIES</span><h2>NuGet</h2></div><span class="count-badge">@installedPackages.Count</span></div>
            <div class="package-search">
                <input @bind="packageQuery" @bind:event="oninput" placeholder="Humanizer.Core" aria-label="NuGetパッケージ検索" />
                <button @onclick="SearchPackagesAsync" disabled="@(packageBusy || string.IsNullOrWhiteSpace(packageQuery))">検索</button>
            </div>
            @if (!string.IsNullOrWhiteSpace(packageMessage))
            {
                <p class="package-message">@packageMessage</p>
            }
            @if (packageResults.Count > 0)
            {
                <div class="package-results">
                    @foreach (var package in packageResults)
                    {
                        <div class="package-item" @key="package.PackageId">
                            <div><strong>@package.PackageId</strong><span>@package.Version · @package.Authors</span></div>
                            <button @onclick="() => InstallPackageAsync(package)" disabled="@packageBusy">追加</button>
                            <p>@package.Description</p>
                        </div>
                    }
                </div>
            }
            @if (installedPackages.Count > 0)
            {
                <div class="installed-list">
                    @foreach (var package in installedPackages)
                    {
                        <span><code>@package.Id</code> @package.Version</span>
                    }
                </div>
            }
        </section>

        <section class="panel side-panel">
            <div class="side-heading"><div><span class="eyebrow">FILES</span><h2>ファイル・DLL</h2></div><span class="count-badge">@referenceNames.Count</span></div>
            <label class="file-drop" @ref="dropZone">
                <InputFile OnChange="HandleFileSelectedAsync" accept=".dll,.pgsworkspace,.json,.jsonl,.ndjson,.txt,.csv,.log" />
                <strong>ドロップまたは選択</strong>
                <span>DLLは参照追加、データは読込コードを挿入、.pgsworkspaceは復元</span>
            </label>
            @if (referenceNames.Count > 0)
            {
                <div class="reference-list">
                    @foreach (var reference in referenceNames)
                    {
                        <code>@reference</code>
                    }
                </div>
            }
        </section>

        <section class="panel side-panel">
            <div class="side-heading"><div><span class="eyebrow">CONTEXT</span><h2>using</h2></div><span class="count-badge">@usings.Count</span></div>
            <div class="using-add">
                <input @bind="newUsing" @bind:event="oninput" placeholder="System.Net.Http" aria-label="追加する名前空間" />
                <button @onclick="AddUsingAsync" disabled="@(isBusy || string.IsNullOrWhiteSpace(newUsing))">追加</button>
            </div>
            <div class="using-list">
                @foreach (var item in usings)
                {
                    <div class="using-chip" @key="item"><code>@item</code><button title="削除（実行状態をリセット）" @onclick="() => RemoveUsingAsync(item)" disabled="@isBusy">×</button></div>
                }
            </div>
        </section>

        <section class="panel roadmap-panel">
            <span class="eyebrow">EXPERIMENTAL</span>
            <h2>現在の境界</h2>
            <ul>
                <li class="done"><span></span>Roslyn IntelliSense</li>
                <li class="done"><span></span>NuGet・DLL・ファイル</li>
                <li class="done"><span></span>ワークスペース保存／復元</li>
                <li><span></span>完全なブラウザー内実行</li>
            </ul>
        </section>
    </aside>
</main>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="toast @messageKind" role="status"><span>@message</span><button @onclick="() => message = null">×</button></div>
}
