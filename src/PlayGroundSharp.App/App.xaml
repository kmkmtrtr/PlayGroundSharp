<Application x:Class="PlayGroundSharp.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <SolidColorBrush x:Key="BackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="PanelBrush" Color="#F8F9FA" />
        <SolidColorBrush x:Key="BorderBrush" Color="#DADCE0" />
        <SolidColorBrush x:Key="ForegroundBrush" Color="#202124" />
        <SolidColorBrush x:Key="MutedBrush" Color="#5F6368" />
        <SolidColorBrush x:Key="AccentBrush" Color="#1967D2" />
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Margin" Value="3,0" />
        </Style>
    </Application.Resources>
</Application>
