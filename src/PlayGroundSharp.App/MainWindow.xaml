<Window x:Class="PlayGroundSharp.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="PlayGroundSharp" Width="1120" Height="760" MinWidth="760" MinHeight="520"
        Background="{StaticResource BackgroundBrush}" Foreground="{StaticResource ForegroundBrush}"
        Loaded="Window_Loaded" Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="27" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel Margin="12,7">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Content="References" Command="{Binding ToggleReferenceDrawerCommand}" />
                    <Button Content="Stop" Command="{Binding CancelCommand}" IsEnabled="{Binding IsRunning}" />
                    <Button Content="Restart Worker" Command="{Binding RestartWorkerCommand}" />
                    <Button Content="Reset" Command="{Binding ResetCommand}" />
                    <Button Content="Clear" Command="{Binding ClearCommand}" />
                </StackPanel>
                <TextBlock Text="PlayGroundSharp" FontSize="17" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock Text="  C# Interactive Console" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Background="{StaticResource BackgroundBrush}">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <ScrollViewer x:Name="TranscriptScroll" Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="16,12,16,4">
                <Grid MinHeight="{Binding ActualHeight, ElementName=TranscriptScroll}">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                  </Grid.RowDefinitions>
                  <ItemsControl Grid.Row="0" ItemsSource="{Binding Transcript}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2,0,7">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Prefix}" Foreground="{Binding PrefixBrush}" FontFamily="Cascadia Mono,Consolas" />
                                <TextBlock Grid.Column="1" Text="{Binding Text}" TextWrapping="Wrap" FontFamily="Cascadia Mono,Consolas"
                                           Foreground="{Binding TextBrush}" MouseLeftButtonUp="TranscriptLine_MouseLeftButtonUp" Cursor="Hand" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <Grid Grid.Row="1" Margin="0,2,0,10">
                <Grid.ColumnDefinitions><ColumnDefinition Width="56"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <TextBlock Text="›" Foreground="{StaticResource AccentBrush}" FontSize="22" VerticalAlignment="Top" HorizontalAlignment="Center" />
                <avalon:TextEditor x:Name="Editor" Grid.Column="1" MinHeight="56" MaxHeight="280"
                                   FontFamily="Cascadia Mono,Consolas" FontSize="14" ShowLineNumbers="True"
                                   Background="#FFFFFF" Foreground="#202124" CaretOffset="0"
                                   HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                   PreviewKeyDown="Editor_PreviewKeyDown" TextChanged="Editor_TextChanged"
                                   MouseHover="Editor_MouseHover" />
                <Border x:Name="CompletionPanel" Grid.Column="1" Panel.ZIndex="10" Visibility="Collapsed"
                        VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="0,0,0,8"
                        Background="#FFFFFF" BorderBrush="#BDC1C6" BorderThickness="1" CornerRadius="3" MaxHeight="260" MinWidth="320">
                        <ListBox x:Name="CompletionList" Background="#FFFFFF" Foreground="#202124" BorderThickness="0"
                                 FontFamily="Cascadia Mono,Consolas" MouseDoubleClick="CompletionList_MouseDoubleClick" />
                </Border>
                  </Grid>
                </Grid>
            </ScrollViewer>
            <Border Grid.Column="1" Width="300" Background="#F8F9FA" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1,0,0,0" Visibility="{Binding IsReferenceDrawerOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="References" FontSize="16" FontWeight="SemiBold" Margin="14,12" />
                    <TabControl Background="#F8F9FA" BorderThickness="0">
                        <TabItem Header="Packages"><ListBox ItemsSource="{Binding PackageItems}" BorderThickness="0" Background="White" /></TabItem>
                        <TabItem Header="Assemblies"><ListBox ItemsSource="{Binding ReferenceItems}" BorderThickness="0" Background="White" /></TabItem>
                        <TabItem Header="Usings"><ListBox ItemsSource="{Binding UsingItems}" BorderThickness="0" Background="White" /></TabItem>
                        <TabItem Header="Session">
                            <StackPanel Margin="10">
                                <TextBlock Text="{Binding SessionStatus}" TextWrapping="Wrap" />
                                <TextBlock Text="Arbitrary C# runs with your Windows user permissions." Margin="0,12,0,0" TextWrapping="Wrap" Foreground="#B3261E" />
                            </StackPanel>
                        </TabItem>
                    </TabControl>
                </DockPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#F1F3F4" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="10,3">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right" Text="{Binding CursorStatus}" Foreground="{StaticResource MutedBrush}" />
                <TextBlock DockPanel.Dock="Right" Margin="18,0" Text="{Binding DiagnosticStatus}" Foreground="{StaticResource MutedBrush}" />
                <TextBlock Text="{Binding Status}" Foreground="{StaticResource AccentBrush}" />
                <TextBlock Text="{Binding SessionStatus}" Margin="18,0" Foreground="{StaticResource MutedBrush}" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
