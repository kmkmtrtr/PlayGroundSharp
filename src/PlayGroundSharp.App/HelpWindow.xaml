<Window x:Class="PlayGroundSharp.App.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Help.Title}" Width="920" Height="680" MinWidth="720" MinHeight="500"
        Background="{DynamicResource BackgroundBrush}" Foreground="{DynamicResource ForegroundBrush}"
        WindowStartupLocation="CenterOwner" PreviewKeyDown="Window_PreviewKeyDown">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border Background="{DynamicResource DrawerBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel Margin="12">
                <StackPanel DockPanel.Dock="Top" Margin="6,4,6,14">
                    <TextBlock Text="PlayGroundSharp" FontSize="19" FontWeight="SemiBold" />
                    <TextBlock Text="{DynamicResource Help.Title}" Foreground="{DynamicResource MutedBrush}" Margin="0,3,0,0" />
                </StackPanel>
                <ListBox ItemsSource="{Binding Topics}" SelectedItem="{Binding SelectedTopic}" BorderThickness="0" Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="2">
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Subtitle}" FontSize="10.5" Foreground="{DynamicResource MutedBrush}"
                                           TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxHeight="32" Margin="0,2,0,0" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="34,28,38,32">
            <StackPanel DataContext="{Binding SelectedTopic}">
                <TextBlock Text="{Binding Title}" FontSize="25" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Subtitle}" FontSize="13.5" Foreground="{DynamicResource MutedBrush}"
                           TextWrapping="Wrap" Margin="0,5,0,22" />
                <ItemsControl ItemsSource="{Binding Sections}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,24">
                                <TextBlock Text="{Binding Heading}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,7" />
                                <TextBlock Text="{Binding Body}" TextWrapping="Wrap" LineHeight="21" />
                                <Border Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="6" Margin="0,10,0,0" Padding="12,10">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Code}" Value="{x:Null}"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                                <DataTrigger Binding="{Binding Code}" Value=""><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBox Text="{Binding Code}" IsReadOnly="True" BorderThickness="0" Padding="0"
                                             Background="Transparent" FontFamily="Cascadia Mono,Consolas" FontSize="12.5"
                                             TextWrapping="NoWrap" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" />
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
