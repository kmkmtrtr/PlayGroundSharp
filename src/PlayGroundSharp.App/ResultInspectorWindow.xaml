<Window x:Class="PlayGroundSharp.App.ResultInspectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PlayGroundSharp.App"
        Title="{DynamicResource Inspector.Title}" Width="760" Height="560" MinWidth="480" MinHeight="340"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}" Foreground="{DynamicResource ForegroundBrush}"
        Loaded="Window_Loaded" PreviewKeyDown="Window_PreviewKeyDown">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition x:Name="SnapshotTreeRow" Height="2*" />
            <RowDefinition Height="5" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid Margin="2,0,0,8">
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,7,0,0">
                <Button x:Name="ExpandSelectedButton" Content="{DynamicResource Inspector.Expand}" Style="{StaticResource MiniButtonStyle}"
                        Click="ExpandSelected_Click" />
                <Button x:Name="CollapseSelectedButton" Content="{DynamicResource Inspector.Collapse}" Style="{StaticResource MiniButtonStyle}"
                        Click="CollapseSelected_Click" Margin="4,0,0,0" />
                <Button x:Name="CopySelectedButton" Content="{DynamicResource Inspector.CopySelected}" Style="{StaticResource MiniButtonStyle}"
                        Click="CopySelected_Click" Margin="8,0,0,0"
                        ToolTip="{DynamicResource Inspector.CopySelectedTooltip}" />
                <Button Content="{DynamicResource Inspector.CopyAll}" Style="{StaticResource MiniButtonStyle}"
                        Click="CopyAll_Click" Margin="4,0,0,0"
                        ToolTip="{DynamicResource Inspector.CopyAllTooltip}" />
                <Button Content="{DynamicResource Inspector.SaveAll}" Style="{StaticResource MiniButtonStyle}"
                        Click="SaveAll_Click" Margin="4,0,0,0"
                        ToolTip="{DynamicResource Inspector.SaveAllTooltip}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{DynamicResource Inspector.Snapshot}" Foreground="{DynamicResource MutedBrush}"
                           VerticalAlignment="Center" Margin="0,0,12,0" />
                <Button x:Name="TreeModeButton" Content="{DynamicResource Inspector.TreeView}" Style="{StaticResource MiniButtonStyle}"
                        Click="TreeMode_Click" Margin="0,0,4,0" />
                <Button x:Name="TableModeButton" Content="{DynamicResource Inspector.TableView}" Style="{StaticResource MiniButtonStyle}"
                        Click="TableMode_Click" ToolTip="{DynamicResource Inspector.TableUnavailableTooltip}" />
            </StackPanel>
        </Grid>
        <Grid x:Name="TreeSearchPanel" Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="{DynamicResource Inspector.Search}" VerticalAlignment="Center" Margin="2,0,8,0" />
            <TextBox x:Name="SearchBox" Grid.Column="1" TextChanged="SearchBox_TextChanged"
                     AutomationProperties.Name="{DynamicResource Inspector.Search}"
                     ToolTip="{DynamicResource Inspector.SearchTooltip}"
                     Background="{DynamicResource InputBrush}" Foreground="{DynamicResource ForegroundBrush}"
                     BorderBrush="{DynamicResource BorderBrush}" Padding="6,4" />
            <TextBlock x:Name="SearchStatus" Grid.Column="2" Foreground="{DynamicResource MutedBrush}"
                       AutomationProperties.LiveSetting="Polite"
                       VerticalAlignment="Center" Margin="10,0,2,0" MinWidth="70" TextAlignment="Right" />
        </Grid>
        <TreeView x:Name="SnapshotTree" Grid.Row="2" ItemsSource="{Binding Roots}"
                  AutomationProperties.Name="{DynamicResource Inspector.Snapshot}"
                  Background="{DynamicResource InputBrush}" Foreground="{DynamicResource ForegroundBrush}"
                  BorderBrush="{DynamicResource BorderBrush}" SelectedItemChanged="SnapshotTree_SelectedItemChanged">
            <TreeView.Resources>
                <HierarchicalDataTemplate DataType="{x:Type local:SnapshotTreeNode}" ItemsSource="{Binding Children}">
                    <TextBlock Text="{Binding Label}" FontFamily="Cascadia Mono,Consolas">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSearchMatch}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </HierarchicalDataTemplate>
            </TreeView.Resources>
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                    <Setter Property="AutomationProperties.Name" Value="{Binding Label}" />
                    <Setter Property="AutomationProperties.HelpText" Value="{Binding Detail}" />
                </Style>
            </TreeView.ItemContainerStyle>
        </TreeView>
        <GridSplitter x:Name="TreeSplitter" Grid.Row="3" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                      Background="Transparent" ShowsPreview="True" Cursor="SizeNS" />
        <DockPanel x:Name="TreeSelectionPanel" Grid.Row="4" Margin="2,5,0,5">
            <Button x:Name="CopyPathButton" Content="{DynamicResource Inspector.CopyPath}" Style="{StaticResource MiniButtonStyle}"
                    DockPanel.Dock="Right" Click="CopyPath_Click" />
            <TextBlock x:Name="PathText" FontFamily="Cascadia Mono,Consolas" TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center" Foreground="{DynamicResource MutedBrush}" />
        </DockPanel>
        <TextBox x:Name="DetailText" Grid.Row="5" IsReadOnly="True" TextWrapping="Wrap"
                 AutomationProperties.Name="{DynamicResource Inspector.Details}"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 Background="{DynamicResource InputBrush}" Foreground="{DynamicResource ForegroundBrush}"
                 BorderBrush="{DynamicResource BorderBrush}" FontFamily="Cascadia Mono,Consolas" Padding="8" />
        <Grid x:Name="TablePanel" Grid.Row="1" Grid.RowSpan="5" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <DockPanel Margin="2,0,0,8">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Content="{DynamicResource Inspector.CopyTable}" Style="{StaticResource MiniButtonStyle}"
                            Click="CopyTable_Click" ToolTip="{DynamicResource Inspector.CopyTableTooltip}" />
                    <Button Content="{DynamicResource Inspector.SaveTable}" Style="{StaticResource MiniButtonStyle}"
                            Click="SaveTable_Click" Margin="4,0,0,0" />
                </StackPanel>
                <TextBlock x:Name="TableStatus" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center"
                           AutomationProperties.LiveSetting="Polite" />
            </DockPanel>
            <DataGrid x:Name="TableGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                      AutomationProperties.Name="{DynamicResource Inspector.TableView}"
                      Background="{DynamicResource InputBrush}" Foreground="{DynamicResource ForegroundBrush}"
                      BorderBrush="{DynamicResource BorderBrush}" GridLinesVisibility="All"
                      HorizontalGridLinesBrush="{DynamicResource BorderBrush}" VerticalGridLinesBrush="{DynamicResource BorderBrush}"
                      HeadersVisibility="All" RowHeaderWidth="58" RowHeight="26"
                      EnableRowVirtualization="True" EnableColumnVirtualization="True"
                      SelectionMode="Extended" SelectionUnit="CellOrRowHeader"
                      ClipboardCopyMode="IncludeHeader" LoadingRow="TableGrid_LoadingRow">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
                        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                        <Setter Property="Padding" Value="7,5" />
                    </Style>
                    <Style TargetType="DataGridRowHeader">
                        <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
                        <Setter Property="Foreground" Value="{DynamicResource MutedBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                        <Setter Property="HorizontalContentAlignment" Value="Right" />
                        <Setter Property="Padding" Value="5,0" />
                    </Style>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                        <Setter Property="Padding" Value="6,3" />
                    </Style>
                </DataGrid.Resources>
            </DataGrid>
        </Grid>
    </Grid>
</Window>
