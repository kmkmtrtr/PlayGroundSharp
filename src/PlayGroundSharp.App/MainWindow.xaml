<Window x:Class="PlayGroundSharp.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:local="clr-namespace:PlayGroundSharp.App"
        Title="PlayGroundSharp" Width="1200" Height="800" MinWidth="820" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}" Foreground="{DynamicResource ForegroundBrush}"
        Loaded="Window_Loaded" Closing="Window_Closing" Deactivated="Window_Deactivated"
        SizeChanged="Window_SizeChanged" StateChanged="Window_StateChanged"
        PreviewKeyDown="Window_PreviewKeyDown" PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown">
    <Window.Resources>
        <DataTemplate x:Key="CompletionItemTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding DisplayText}" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,2,0">
                    <Border Visibility="{Binding HasNamespaceHint, Converter={StaticResource BooleanToVisibilityConverter}}"
                            ToolTip="{Binding NamespaceDisplayText}" CornerRadius="3" Padding="4,1" Margin="0,0,6,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RequiresImport}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource SelectionBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding NamespaceDisplayText}" Foreground="{DynamicResource MutedBrush}"
                                   FontSize="10" MaxWidth="190" TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                    </Border>
                    <Border Visibility="{Binding IsExtensionMethod, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Background="{DynamicResource SelectionBrush}" CornerRadius="3" Padding="4,1">
                        <TextBlock Text="ext" Foreground="{DynamicResource MutedBrush}" FontSize="9" />
                    </Border>
                </StackPanel>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="SignatureItemTemplate">
            <TextBlock Text="{Binding DisplayText}" />
        </DataTemplate>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="54" />
            <RowDefinition Height="*" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel Margin="16,8">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Content="C#" Command="{Binding ToggleTypeExplorerCommand}"
                            ToolTip="{DynamicResource Tooltip.Types}" AutomationProperties.Name="{DynamicResource Ui.Types}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource IconToolbarButtonStyle}">
                                <Setter Property="FontFamily" Value="Cascadia Mono,Consolas" />
                                <Setter Property="FontSize" Value="11.5" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTypeExplorerOpen}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource SelectionBrush}" />
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="▤" Command="{Binding ToggleReferenceDrawerCommand}"
                            ToolTip="{DynamicResource Tooltip.Session}" AutomationProperties.Name="{DynamicResource Ui.Session}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource IconToolbarButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsReferenceDrawerOpen}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource SelectionBrush}" />
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Border Width="1" Height="20" Background="{DynamicResource BorderBrush}" Margin="7,0" />
                    <Button Content="■" Style="{StaticResource DangerIconToolbarButtonStyle}" IsEnabled="{Binding CanCancel}"
                            ToolTip="{DynamicResource Tooltip.Stop}" AutomationProperties.Name="{DynamicResource Ui.Stop}" FontSize="13"
                            Click="Cancel_Click" />
                    <Button Content="↻" Style="{StaticResource IconToolbarButtonStyle}" Click="RestartWorker_Click"
                            ToolTip="{DynamicResource Tooltip.Restart}" AutomationProperties.Name="{DynamicResource Ui.Restart}"
                            IsEnabled="{Binding CanResetOrRestart}" />
                    <Button Content="⟲" Style="{StaticResource IconToolbarButtonStyle}" Click="ResetSession_Click" IsEnabled="{Binding CanResetOrRestart}"
                            ToolTip="{DynamicResource Tooltip.Reset}" AutomationProperties.Name="{DynamicResource Ui.Reset}" />
                    <Button Content="⌫" Style="{StaticResource IconToolbarButtonStyle}" Command="{Binding ClearCommand}"
                            ToolTip="{DynamicResource Tooltip.Clear}" AutomationProperties.Name="{DynamicResource Ui.Clear}"
                            Click="FocusEditorAfterCommand_Click" />
                </StackPanel>
                <Border DockPanel.Dock="Left" Width="32" Height="32" CornerRadius="8" Background="{DynamicResource SelectionBrush}" Margin="0,0,10,0">
                    <TextBlock Text=">_" Foreground="{DynamicResource AccentBrush}" FontFamily="Cascadia Mono,Consolas"
                               FontSize="13" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock Text="PlayGroundSharp" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Text="{DynamicResource Ui.AppSubtitle}" FontSize="10.5" Foreground="{DynamicResource MutedBrush}" />
                </StackPanel>
                <Menu DockPanel.Dock="Left" Style="{StaticResource HeaderMenuStyle}" Margin="18,0,0,0">
                    <MenuItem Header="{DynamicResource Menu.File}" Style="{StaticResource HeaderMenuItemStyle}">
                        <MenuItem Header="{DynamicResource Menu.SaveWorkspace}" Click="SaveWorkspace_Click" InputGestureText="Ctrl+Shift+S"
                                  IsEnabled="{Binding CanSaveWorkspace}" />
                        <MenuItem Header="{DynamicResource Menu.OpenWorkspace}" Click="OpenWorkspace_Click" InputGestureText="Ctrl+O"
                                  IsEnabled="{Binding CanOpenWorkspace}" />
                        <Separator />
                        <MenuItem Header="{DynamicResource Menu.Exit}" Click="Exit_Click" />
                    </MenuItem>
                    <MenuItem Header="{DynamicResource Menu.Edit}" Style="{StaticResource HeaderMenuItemStyle}">
                        <MenuItem Header="{DynamicResource Menu.FocusInput}" Click="FocusInput_Click" InputGestureText="Ctrl+L" />
                        <MenuItem Header="{DynamicResource Menu.SearchSymbols}" Click="FocusExplorerSearch_Click" InputGestureText="Ctrl+F" />
                        <Separator />
                        <MenuItem Header="{DynamicResource Menu.CopyTranscript}" Click="CopyTranscript_Click" InputGestureText="Ctrl+Shift+C" />
                        <MenuItem Header="{DynamicResource Menu.SaveTranscript}" Click="SaveTranscript_Click" />
                        <Separator />
                        <MenuItem Header="{DynamicResource Menu.ClearTranscript}" Command="{Binding ClearCommand}"
                                  Click="FocusEditorAfterCommand_Click" />
                    </MenuItem>
                    <MenuItem Header="{DynamicResource Menu.Data}" Style="{StaticResource HeaderMenuItemStyle}">
                        <MenuItem Header="{DynamicResource Menu.InspectFile}" Tag="Inspect" Click="InsertDataSnippet_Click" />
                        <MenuItem Header="{DynamicResource Menu.PreviewText}" Tag="Preview" Click="InsertDataSnippet_Click" />
                        <MenuItem Header="{DynamicResource Menu.ReadLines}" Tag="Lines" Click="InsertDataSnippet_Click" />
                        <Separator />
                        <MenuItem Header="{DynamicResource Menu.ReadJson}" Tag="Json" Click="InsertDataSnippet_Click" />
                        <MenuItem Header="{DynamicResource Menu.ReadJsonArray}" Tag="JsonArray" Click="InsertDataSnippet_Click" />
                        <MenuItem Header="{DynamicResource Menu.ReadJsonLines}" Tag="JsonLines" Click="InsertDataSnippet_Click" />
                    </MenuItem>
                    <MenuItem Header="{DynamicResource Menu.View}" Style="{StaticResource HeaderMenuItemStyle}">
                        <MenuItem Header="{DynamicResource Menu.SymbolExplorer}" Command="{Binding ToggleTypeExplorerCommand}"
                                  IsCheckable="True" IsChecked="{Binding IsTypeExplorerOpen, Mode=OneWay}" />
                        <MenuItem Header="{DynamicResource Menu.Workspace}" Command="{Binding ToggleReferenceDrawerCommand}"
                                  IsCheckable="True" IsChecked="{Binding IsReferenceDrawerOpen, Mode=OneWay}" />
                    </MenuItem>
                    <MenuItem Header="{DynamicResource Menu.Help}" Style="{StaticResource HeaderMenuItemStyle}">
                        <MenuItem Header="{DynamicResource Menu.OpenHelp}" Click="OpenHelp_Click" InputGestureText="F1" />
                        <Separator />
                        <MenuItem Header="{DynamicResource Menu.About}" Click="About_Click" />
                    </MenuItem>
                </Menu>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Background="{DynamicResource BackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="TypeExplorerColumn" Width="286" />
                <ColumnDefinition x:Name="TypeExplorerSplitterColumn" Width="5" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="ReferenceDrawerSplitterColumn" Width="0" />
                <ColumnDefinition x:Name="ReferenceDrawerColumn" Width="0" />
            </Grid.ColumnDefinitions>
            <Border x:Name="TypeExplorerPane" Grid.Column="0" MinWidth="220" MaxWidth="520" Background="{DynamicResource DrawerBrush}" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,1,0" Visibility="{Binding IsTypeExplorerOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
                    IsVisibleChanged="TypeExplorerPane_IsVisibleChanged">
                <DockPanel>
                    <Border DockPanel.Dock="Top" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="14,12,12,10">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Explorer.Title}" FontSize="14" FontWeight="SemiBold" />
                                <TextBlock Text="{DynamicResource Explorer.Subtitle}" FontSize="10.5" Foreground="{DynamicResource MutedBrush}" Margin="0,2,0,0" />
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="{Binding TypeExplorerStatus}" FontSize="10.5" Foreground="{DynamicResource MutedBrush}"
                                       VerticalAlignment="Top" Margin="8,2,0,0" />
                        </Grid>
                    </Border>
                    <Grid Margin="10,10,8,8">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <Grid>
                            <TextBox x:Name="TypeExplorerSearchBox" Text="{Binding TypeExplorerSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     AutomationProperties.Name="TypeExplorerSearch" ToolTip="{DynamicResource Explorer.FilterTooltip}"
                                     Height="32" Padding="9,4" VerticalContentAlignment="Center"
                                     PreviewKeyDown="TypeExplorerSearchBox_PreviewKeyDown" />
                            <TextBlock Text="{DynamicResource Explorer.Filter}" Foreground="{DynamicResource MutedBrush}" Margin="10,0,0,0"
                                       VerticalAlignment="Center" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers><DataTrigger Binding="{Binding TypeExplorerSearchText}" Value=""><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <Grid Grid.Row="1" Margin="0,8,0,0">
                            <TreeView x:Name="TypeExplorerTree" ItemsSource="{Binding TypeExplorerItems}" AutomationProperties.Name="TypeExplorerTree"
                                      Background="Transparent" BorderThickness="0" Foreground="{DynamicResource ForegroundBrush}"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto" SelectedItemChanged="TypeExplorerTree_SelectedItemChanged"
                                      VirtualizingStackPanel.IsVirtualizing="True"
                                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                                      ScrollViewer.CanContentScroll="True"
                                      PreviewMouseLeftButtonUp="TypeExplorerTree_PreviewMouseLeftButtonUp"
                                      PreviewMouseWheel="TypeExplorerTree_PreviewMouseWheel"
                                      PreviewKeyDown="TypeExplorerTree_PreviewKeyDown">
                                <TreeView.Resources>
                                    <Style x:Key="ExplorerKindTextStyle" TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Kind}" Value="namespace"><Setter Property="Foreground" Value="{DynamicResource ExplorerNamespaceBrush}" /></DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="class"><Setter Property="Foreground" Value="{DynamicResource ExplorerClassBrush}" /></DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="record"><Setter Property="Foreground" Value="{DynamicResource ExplorerRecordBrush}" /></DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="record struct"><Setter Property="Foreground" Value="{DynamicResource ExplorerRecordBrush}" /></DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="interface"><Setter Property="Foreground" Value="{DynamicResource ExplorerInterfaceBrush}" /></DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="struct"><Setter Property="Foreground" Value="{DynamicResource ExplorerStructBrush}" /></DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="enum"><Setter Property="Foreground" Value="{DynamicResource ExplorerEnumBrush}" /></DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="enum member"><Setter Property="Foreground" Value="{DynamicResource ExplorerEnumBrush}" /></DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="delegate"><Setter Property="Foreground" Value="{DynamicResource ExplorerDelegateBrush}" /></DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="method"><Setter Property="Foreground" Value="{DynamicResource ExplorerMethodBrush}" /></DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="constructor"><Setter Property="Foreground" Value="{DynamicResource ExplorerMethodBrush}" /></DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                    <HierarchicalDataTemplate DataType="{x:Type local:SymbolExplorerNode}" ItemsSource="{Binding Children}">
                                        <Grid Margin="0,1" ToolTipService.InitialShowDelay="180" ToolTipService.ShowDuration="15000">
                                            <Grid.ToolTip>
                                                <ToolTip Placement="Mouse" HorizontalOffset="12" VerticalOffset="8">
                                                    <Border Background="{DynamicResource OverlayBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                                            BorderThickness="1" CornerRadius="7" Padding="11,9" MaxWidth="440">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Signature}" FontFamily="Cascadia Mono,Consolas"
                                                                       FontSize="11.5" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                            <TextBlock Text="{DynamicResource Docs.Inheritance}" Foreground="{DynamicResource MutedBrush}"
                                                                       FontSize="10.5" FontWeight="SemiBold" Margin="0,7,0,1"
                                                                       Visibility="{Binding HasInheritance, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                            <TextBlock Text="{Binding InheritanceDisplay}" FontFamily="Cascadia Mono,Consolas"
                                                                       FontSize="11" TextWrapping="Wrap"
                                                                       Visibility="{Binding HasInheritance, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                            <TextBlock Text="{DynamicResource Docs.Summary}" Foreground="{DynamicResource MutedBrush}"
                                                                       FontSize="10.5" FontWeight="SemiBold" Margin="0,7,0,1" />
                                                            <TextBlock FontSize="11.5" TextWrapping="Wrap">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text" Value="{Binding Summary}" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasSummary}" Value="False">
                                                                                <Setter Property="Text" Value="{DynamicResource Docs.NoSummary}" />
                                                                                <Setter Property="Foreground" Value="{DynamicResource MutedBrush}" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <TextBlock Text="{DynamicResource Docs.HoverHint}" Foreground="{DynamicResource MutedBrush}"
                                                                       FontSize="10.5" Margin="0,7,0,0" />
                                                        </StackPanel>
                                                    </Border>
                                                    <ToolTip.Style>
                                                        <Style TargetType="ToolTip">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Signature}" Value=""><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ToolTip.Style>
                                                </ToolTip>
                                            </Grid.ToolTip>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <Border Width="20" Height="20" CornerRadius="4" Background="{DynamicResource SelectionBrush}" Margin="0,0,6,0">
                                                <TextBlock Text="{Binding Glyph}" Style="{StaticResource ExplorerKindTextStyle}" FontFamily="Cascadia Mono,Consolas"
                                                           FontSize="10.5" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" Style="{StaticResource ExplorerKindTextStyle}"
                                                       FontSize="12.5" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                            <Border Grid.Column="2" Background="{DynamicResource InputBrush}" CornerRadius="4" Padding="5,1"
                                                    Margin="7,0,2,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding KindLabel}" Style="{StaticResource ExplorerKindTextStyle}"
                                                           FontSize="9.5" VerticalAlignment="Center" />
                                            </Border>
                                        </Grid>
                                    </HierarchicalDataTemplate>
                                </TreeView.Resources>
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=OneTime}" />
                                        <Setter Property="AutomationProperties.Name" Value="{Binding Name}" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="1" />
                                    </Style>
                                </TreeView.ItemContainerStyle>
                            </TreeView>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                                <TextBlock Text="{DynamicResource Explorer.Empty}" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                <TextBlock Text="{DynamicResource Explorer.EmptyHint}" Foreground="{DynamicResource MutedBrush}" FontSize="10.5" Margin="0,4,0,0" />
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers><DataTrigger Binding="{Binding TypeExplorerItems.Count}" Value="0"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </DockPanel>
            </Border>
            <GridSplitter Grid.Column="1" Style="{StaticResource VerticalPaneSplitterStyle}"
                          AutomationProperties.Name="{DynamicResource Tooltip.ResizeExplorer}"
                          ToolTip="{DynamicResource Tooltip.ResizeExplorer}"
                          Visibility="{Binding IsTypeExplorerOpen, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <Popup x:Name="SymbolDetailPopup" PlacementTarget="{Binding ElementName=TypeExplorerTree}" Placement="Right"
                   HorizontalOffset="8" StaysOpen="True" AllowsTransparency="True">
                <Border Width="440" MaxHeight="560" Background="{DynamicResource OverlayBrush}" BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="9" Padding="16,14">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.18" />
                    </Border.Effect>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel DataContext="{Binding SelectedExplorerNode}">
                            <TextBlock Text="{Binding Signature}" FontFamily="Cascadia Mono,Consolas" FontSize="12"
                                       FontWeight="SemiBold" TextWrapping="Wrap" />
                            <TextBlock Text="{DynamicResource Docs.Inheritance}" FontSize="10.5" FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}" Margin="0,12,0,3"
                                       Visibility="{Binding HasInheritance, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <TextBlock Text="{Binding InheritanceDisplay}" FontFamily="Cascadia Mono,Consolas" FontSize="11.5" TextWrapping="Wrap" LineHeight="18"
                                       Visibility="{Binding HasInheritance, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <TextBlock Text="{DynamicResource Docs.Summary}" FontSize="10.5" FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}" Margin="0,12,0,3" />
                            <TextBlock FontSize="11.5" TextWrapping="Wrap" LineHeight="18">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding Summary}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasSummary}" Value="False">
                                                <Setter Property="Text" Value="{DynamicResource Docs.NoSummary}" />
                                                <Setter Property="Foreground" Value="{DynamicResource MutedBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{DynamicResource Docs.Parameters}" FontSize="10.5" FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}" Margin="0,12,0,3"
                                       Visibility="{Binding HasParameters, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <ItemsControl ItemsSource="{Binding ParameterItems}" Visibility="{Binding HasParameters, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,1,0,7">
                                            <TextBlock FontFamily="Cascadia Mono,Consolas" FontSize="11">
                                                <Run Text="{Binding Name}" FontWeight="SemiBold"/><Run Text=" : "/><Run Text="{Binding TypeName}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Summary}" TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource MutedBrush}" Margin="8,2,0,0" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="{DynamicResource Docs.Returns}" FontSize="10.5" FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}" Margin="0,8,0,3"
                                       Visibility="{Binding HasReturns, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <TextBlock Text="{Binding Returns}" FontSize="11.5" TextWrapping="Wrap" LineHeight="18"
                                       Visibility="{Binding HasReturns, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <TextBlock Text="{Binding AssemblyName}" FontSize="10.5" Foreground="{DynamicResource MutedBrush}" Margin="0,12,0,0" />
                            <Button Content="{DynamicResource Docs.OpenJapanese}" Style="{StaticResource MiniButtonStyle}"
                                    HorizontalAlignment="Left" Margin="-6,9,0,0" Click="OpenSymbolDocumentation_Click"
                                    Visibility="{Binding HasOnlineDocumentation, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Popup>
            <Grid Grid.Column="2">
            <ScrollViewer x:Name="TranscriptScroll" VerticalScrollBarVisibility="Auto" Padding="20,16,18,6"
                          AutomationProperties.Name="ConsoleSurface"
                          PreviewMouseLeftButtonDown="ConsoleSurface_PreviewMouseLeftButtonDown"
                          PreviewMouseWheel="TranscriptScroll_PreviewMouseWheel"
                          ScrollChanged="TranscriptScroll_ScrollChanged">
                <Grid MinHeight="{Binding ViewportHeight, ElementName=TranscriptScroll}">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                  </Grid.RowDefinitions>
                  <ItemsControl Grid.Row="0" ItemsSource="{Binding Transcript}">
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="AutomationProperties.Name" Value="{Binding Text}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,1,0,5" ContextMenuOpening="TranscriptRow_ContextMenuOpening"
                                  AutomationProperties.Name="{Binding Text}">
                                <Grid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="{DynamicResource Ui.Copy}" Click="CopyTranscriptLine_Click" />
                                        <MenuItem Header="{DynamicResource Ui.CopyJson}"
                                                  Visibility="{Binding IsJsonCopyable, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                  Click="CopyTranscriptLineJson_Click" />
                                        <MenuItem Header="{DynamicResource Ui.Save}"
                                                  Visibility="{Binding IsSavable, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                  Click="SaveTranscriptLine_Click" />
                                        <Separator Visibility="{Binding IsInspectable, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <MenuItem Header="{DynamicResource Ui.Inspect}"
                                                  Visibility="{Binding IsInspectable, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                  Click="InspectResult_Click" />
                                    </ContextMenu>
                                </Grid.ContextMenu>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Prefix}" Foreground="{Binding PrefixBrush}" FontFamily="Cascadia Mono,Consolas"
                                           FontSize="14" FontWeight="SemiBold" />
                                <Grid Grid.Column="1">
                                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap" FontFamily="Cascadia Mono,Consolas"
                                               FontSize="14" LineHeight="20" Foreground="{Binding TextBrush}" MouseLeftButtonUp="TranscriptLine_MouseLeftButtonUp">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Cursor" Value="Arrow" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsInput}" Value="True"><Setter Property="Cursor" Value="Hand" /></DataTrigger>
                                                    <DataTrigger Binding="{Binding IsStructured}" Value="True"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TreeView ItemsSource="{Binding SnapshotRoots}" Background="Transparent" BorderThickness="0"
                                              Padding="0" FontFamily="Cascadia Mono,Consolas" FontSize="14"
                                              Foreground="{DynamicResource ForegroundBrush}" HorizontalContentAlignment="Stretch"
                                              PreviewKeyDown="TranscriptTree_PreviewKeyDown">
                                        <TreeView.Style>
                                            <Style TargetType="TreeView">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsStructured}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TreeView.Style>
                                        <TreeView.Resources>
                                            <HierarchicalDataTemplate DataType="{x:Type local:ConsoleSnapshotNode}" ItemsSource="{Binding Children}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}" />
                                                    <TextBlock Text="{Binding Separator}" Foreground="{DynamicResource ForegroundBrush}" />
                                                    <TextBlock Text="{Binding Preview}" Foreground="{DynamicResource MutedBrush}" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </HierarchicalDataTemplate>
                                        </TreeView.Resources>
                                        <TreeView.ItemContainerStyle>
                                            <Style TargetType="TreeViewItem">
                                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                                <Setter Property="AutomationProperties.Name" Value="{Binding Preview}" />
                                                <Setter Property="Padding" Value="0,1" />
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            </Style>
                                        </TreeView.ItemContainerStyle>
                                    </TreeView>
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <Grid Grid.Row="1" Margin="0,2,0,8">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <Grid.ColumnDefinitions><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <TextBlock Grid.Row="1" Text=">" Foreground="{DynamicResource AccentBrush}" FontSize="15" FontWeight="SemiBold"
                           FontFamily="Cascadia Mono,Consolas" VerticalAlignment="Top" Margin="0,2,0,0" />
                <avalon:TextEditor x:Name="Editor" Grid.Row="1" Grid.Column="1" MinHeight="24" MaxHeight="280"
                                   AutomationProperties.Name="InputEditor"
                                   FontFamily="Cascadia Mono,Consolas" FontSize="14" ShowLineNumbers="False"
                                   Background="{DynamicResource InputBrush}" Foreground="{DynamicResource ForegroundBrush}" CaretOffset="0"
                                   Padding="0,2" BorderThickness="0"
                                   AllowDrop="True" PreviewDragOver="Editor_PreviewDragOver" PreviewDragLeave="Editor_PreviewDragLeave"
                                   PreviewDrop="Editor_PreviewDrop"
                                   HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                   PreviewKeyDown="Editor_PreviewKeyDown" TextChanged="Editor_TextChanged"
                                   MouseHover="Editor_MouseHover" MouseLeave="Editor_MouseLeave" />
                <Border x:Name="DropOverlay" Grid.Row="1" Grid.Column="1" Panel.ZIndex="20" Visibility="Collapsed"
                        IsHitTestVisible="False" Background="{DynamicResource SelectionBrush}"
                        BorderBrush="{DynamicResource AccentBrush}" BorderThickness="2" CornerRadius="5" Padding="12">
                    <TextBlock Text="{DynamicResource Drop.Hint}" Foreground="{DynamicResource AccentBrush}"
                               FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <Popup x:Name="AssistPopup" Grid.Row="1" Grid.Column="1" PlacementTarget="{Binding ElementName=Editor}"
                       Placement="Bottom" VerticalOffset="4" StaysOpen="True" AllowsTransparency="False"
                       Focusable="False">
                    <Border x:Name="AssistPopupBorder" Background="{DynamicResource OverlayBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Width="780" MinWidth="520" MaxWidth="780" Height="310">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="30" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="CompletionListColumn" Width="390" MinWidth="250" />
                                <ColumnDefinition Width="5" />
                                <ColumnDefinition Width="*" MinWidth="250" />
                            </Grid.ColumnDefinitions>
                            <ListBox x:Name="CompletionList" Background="{DynamicResource InputBrush}" Foreground="{DynamicResource ForegroundBrush}" BorderThickness="0"
                                     FontFamily="Cascadia Mono,Consolas" Focusable="False"
                                     SelectionChanged="CompletionList_SelectionChanged"
                                     MouseDoubleClick="CompletionList_MouseDoubleClick">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Focusable" Value="False" />
                                        <Setter Property="AutomationProperties.Name" Value="{Binding AccessibleDisplayText}" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                            <GridSplitter Grid.Column="1" Style="{StaticResource VerticalPaneSplitterStyle}"
                                          AutomationProperties.Name="{DynamicResource Tooltip.ResizeCompletion}"
                                          ToolTip="{DynamicResource Tooltip.ResizeCompletion}"
                                          DragCompleted="CompletionSplitter_DragCompleted" />
                            <Border x:Name="AssistSummaryPanel" Grid.Column="2" Background="{DynamicResource PanelBrush}" Padding="12,10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="{DynamicResource Assist.Documentation}" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,7" />
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                        <TextBlock x:Name="AssistSummary" Foreground="{DynamicResource ForegroundBrush}" TextWrapping="Wrap"
                                                   LineHeight="18" FontFamily="Segoe UI" FontSize="12" />
                                    </ScrollViewer>
                                    <TextBlock Grid.Row="2" Text="{DynamicResource Assist.DocumentationLanguageHint}"
                                               Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" FontSize="10.5"
                                               Margin="0,8,0,0" />
                                </Grid>
                            </Border>
                            <Border Grid.Row="1" Grid.ColumnSpan="3" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                                <TextBlock x:Name="AssistHint" Margin="8,5" Foreground="{DynamicResource MutedBrush}" FontSize="11" />
                            </Border>
                        </Grid>
                    </Border>
                </Popup>
                  </Grid>
                </Grid>
            </ScrollViewer>
            <Button x:Name="ScrollToLatestButton" Content="↓" Style="{StaticResource IconToolbarButtonStyle}"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,16,12"
                    Visibility="Collapsed" Click="ScrollToLatest_Click"
                    ToolTip="{DynamicResource Ui.ScrollToLatest}"
                    AutomationProperties.Name="{DynamicResource Ui.ScrollToLatest}" />
            </Grid>
            <GridSplitter Grid.Column="3" Style="{StaticResource VerticalPaneSplitterStyle}"
                          AutomationProperties.Name="{DynamicResource Tooltip.ResizeWorkspace}"
                          ToolTip="{DynamicResource Tooltip.ResizeWorkspace}"
                          Visibility="{Binding IsReferenceDrawerOpen, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <Border x:Name="ReferenceDrawerPane" Grid.Column="4" MinWidth="320" MaxWidth="720" Background="{DynamicResource DrawerBrush}" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1,0,0,0" Visibility="{Binding IsReferenceDrawerOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
                    IsVisibleChanged="ReferenceDrawerPane_IsVisibleChanged">
                <DockPanel>
                    <Border DockPanel.Dock="Top" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,12,14,10">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Workspace.Title}" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock Text="{DynamicResource Workspace.Subtitle}" FontSize="11" Foreground="{DynamicResource MutedBrush}" Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>
                    <TabControl x:Name="WorkspaceTabs" Background="{DynamicResource DrawerBrush}" Foreground="{DynamicResource ForegroundBrush}" BorderThickness="0"
                                ItemContainerStyle="{StaticResource WorkspaceTabItemStyle}">
                        <TabItem Header="{DynamicResource Tab.Variables}">
                            <Grid TextElement.Foreground="{DynamicResource ForegroundBrush}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid Margin="12,12,12,8">
                                    <TextBox x:Name="VariableSearchBox" Text="{Binding VariableFilterText, UpdateSourceTrigger=PropertyChanged}"
                                             AutomationProperties.Name="VariableSearch" Height="32" Padding="9,4"
                                             VerticalContentAlignment="Center" PreviewKeyDown="VariableSearchBox_PreviewKeyDown" />
                                    <TextBlock Text="{DynamicResource Variables.Filter}" Foreground="{DynamicResource MutedBrush}"
                                               Margin="10,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding VariableFilterText}" Value="">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <ListView x:Name="VariableList" Grid.Row="1" ItemsSource="{Binding VariableItemsView}" AutomationProperties.Name="VariableList" BorderThickness="0" Background="Transparent" Foreground="{DynamicResource ForegroundBrush}"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto" ToolTip="{DynamicResource Variables.InteractionHint}"
                                          MouseDoubleClick="VariableItem_MouseDoubleClick" PreviewKeyDown="VariableItem_PreviewKeyDown"
                                          PreviewMouseRightButtonDown="VariableItem_PreviewMouseRightButtonDown"
                                          ContextMenuOpening="VariableList_ContextMenuOpening">
                                    <ListView.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="{DynamicResource Ui.Copy}" Click="CopyVariable_Click" />
                                            <MenuItem Header="{DynamicResource Ui.Inspect}" Click="InspectVariable_Click" />
                                        </ContextMenu>
                                    </ListView.ContextMenu>
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="AutomationProperties.Name" Value="{Binding Name}" />
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="{DynamicResource Column.Kind}" DisplayMemberBinding="{Binding Kind}" Width="48" />
                                            <GridViewColumn Header="{DynamicResource Column.Name}" Width="110">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate><TextBlock Text="{Binding Name}" ToolTip="{Binding Name}" TextTrimming="CharacterEllipsis" /></DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="{DynamicResource Column.Type}" Width="140">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate><TextBlock Text="{Binding TypeName}" ToolTip="{Binding TypeName}" TextTrimming="CharacterEllipsis" /></DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="{DynamicResource Column.Value}" Width="220">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate><TextBlock Text="{Binding Value}" ToolTip="{Binding Value}" TextTrimming="CharacterEllipsis" /></DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                                <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                                    <TextBlock Text="{DynamicResource Variables.Empty}" Foreground="{DynamicResource ForegroundBrush}" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                    <TextBlock Text="{DynamicResource Variables.EmptyHint}" Foreground="{DynamicResource MutedBrush}" FontSize="11" Margin="0,4,0,0" />
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers><DataTrigger Binding="{Binding VariableItems.Count}" Value="0"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                </StackPanel>
                                <TextBlock Grid.Row="1" Text="{DynamicResource Variables.NoMatches}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{DynamicResource MutedBrush}" IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding VariableFilterText}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding VariableItems.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding HasItems, ElementName=VariableList}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </TabItem>
                        <TabItem Header="{DynamicResource Tab.NuGet}">
                            <Grid Margin="12" TextElement.Foreground="{DynamicResource ForegroundBrush}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBox x:Name="PackageSearchBox" Text="{Binding PackageSearchText, UpdateSourceTrigger=PropertyChanged}"
                                             AutomationProperties.Name="NuGetSearchText" PreviewKeyDown="PackageSearchBox_PreviewKeyDown"
                                             ToolTip="{DynamicResource NuGet.SearchTooltip}" />
                                    <Button Grid.Column="1" Content="{DynamicResource NuGet.Search}" Style="{StaticResource AccentButtonStyle}" AutomationProperties.Name="NuGetSearchButton"
                                            Command="{Binding SearchPackagesCommand}" Margin="7,0,0,0"
                                            IsEnabled="{Binding CanChangeSession}" />
                                </Grid>
                                <CheckBox Grid.Row="1" Content="{DynamicResource NuGet.IncludePrerelease}" IsChecked="{Binding IncludePrereleasePackages}" Margin="0,7,0,0"
                                          IsEnabled="{Binding CanChangeSession}" />
                                <TextBlock Grid.Row="2" Text="{Binding PackageSearchMessage}" Margin="0,7" TextWrapping="Wrap"
                                           Foreground="{DynamicResource MutedBrush}" />
                                <ListBox x:Name="PackageSearchResults" Grid.Row="3" ItemsSource="{Binding PackageSearchItems}" AutomationProperties.Name="NuGetSearchResults" BorderThickness="0"
                                         Background="Transparent" Foreground="{DynamicResource ForegroundBrush}"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled" PreviewKeyDown="PackageSearchResults_PreviewKeyDown">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="AutomationProperties.Name" Value="{Binding PackageId}" />
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource InputBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                    CornerRadius="7" Padding="10" Margin="0,0,0,8">
                                                <Grid>
                                                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding PackageId}" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding Version, StringFormat={}  {0}}" Foreground="{DynamicResource MutedBrush}" />
                                                        <TextBlock Text="{DynamicResource NuGet.Verified}" Foreground="{DynamicResource AccentBrush}"
                                                                   Visibility="{Binding IsVerified, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Grid.RowSpan="2" Content="{DynamicResource NuGet.Install}" Style="{StaticResource AccentButtonStyle}" Padding="10,4"
                                                            Command="{Binding DataContext.InstallPackageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            IsEnabled="{Binding DataContext.CanChangeSession, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                    <TextBlock Grid.Row="1" Text="{Binding Description}" TextWrapping="Wrap" MaxHeight="42" Margin="0,4,8,0" />
                                                    <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Margin="0,4,0,0" Foreground="{DynamicResource MutedBrush}">
                                                        <Run Text="{Binding Authors}"/><Run Text=" · "/><Run Text="{Binding TotalDownloads, StringFormat={}{0:N0}}"/><Run Text="{DynamicResource NuGet.DownloadsSuffix}"/>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </TabItem>
                        <TabItem Header="{DynamicResource Tab.Libraries}">
                            <Grid TextElement.Foreground="{DynamicResource ForegroundBrush}">
                                <ListView ItemsSource="{Binding LibraryItems}" AutomationProperties.Name="ImportedLibraryList" BorderThickness="0" Background="Transparent"
                                          Foreground="{DynamicResource ForegroundBrush}" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="AutomationProperties.Name" Value="{Binding Name}" />
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="{DynamicResource Column.Kind}" DisplayMemberBinding="{Binding Kind}" Width="72" />
                                            <GridViewColumn Header="{DynamicResource Column.Name}" DisplayMemberBinding="{Binding Name}" Width="150" />
                                            <GridViewColumn Header="{DynamicResource Column.Version}" DisplayMemberBinding="{Binding Version}" Width="92" />
                                            <GridViewColumn Header="{DynamicResource Column.Source}" DisplayMemberBinding="{Binding Source}" Width="160" />
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                                    <TextBlock Text="{DynamicResource Libraries.Empty}" Foreground="{DynamicResource ForegroundBrush}" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                    <TextBlock Text="{DynamicResource Libraries.EmptyHint}" Foreground="{DynamicResource MutedBrush}" FontSize="11" Margin="0,4,0,0" />
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers><DataTrigger Binding="{Binding LibraryItems.Count}" Value="0"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                </StackPanel>
                            </Grid>
                        </TabItem>
                        <TabItem Header="{DynamicResource Tab.Usings}">
                            <Grid Margin="10" TextElement.Foreground="{DynamicResource ForegroundBrush}">
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBox x:Name="NewUsingBox" Text="{Binding NewUsingText, UpdateSourceTrigger=PropertyChanged}"
                                             Height="32" Padding="9,4" PreviewKeyDown="NewUsingBox_PreviewKeyDown"
                                             AutomationProperties.Name="UsingInput"
                                             VerticalContentAlignment="Center" ToolTip="{DynamicResource Usings.InputTooltip}" />
                                    <Button Grid.Column="1" Content="{DynamicResource Usings.Add}" Command="{Binding AddUsingFromGuiCommand}"
                                            Style="{StaticResource AccentButtonStyle}" Margin="7,0,0,0" MinWidth="64"
                                            IsEnabled="{Binding CanChangeSession}" />
                                </Grid>
                                <ListBox x:Name="UsingList" Grid.Row="1" ItemsSource="{Binding UsingItems}" Margin="0,9,0,0" BorderThickness="0"
                                         Background="Transparent" Foreground="{DynamicResource ForegroundBrush}"
                                         PreviewKeyDown="UsingList_PreviewKeyDown" ToolTip="{DynamicResource Usings.ListTooltip}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="2,2" MinWidth="220">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding}" FontFamily="Cascadia Mono,Consolas" VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" ToolTip="{Binding}" />
                                                <Button Grid.Column="1" Content="×" Click="RemoveUsing_Click"
                                                        Style="{StaticResource InlineRemoveButtonStyle}"
                                                        IsEnabled="{Binding DataContext.CanChangeSession, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        ToolTip="{DynamicResource Usings.Remove}"
                                                        AutomationProperties.Name="{DynamicResource Usings.Remove}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </TabItem>
                        <TabItem Header="{DynamicResource Tab.Settings}">
                            <StackPanel Margin="14" TextElement.Foreground="{DynamicResource ForegroundBrush}">
                                <Border Background="{DynamicResource InputBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="7" Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource Ui.Session}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding SessionStatus}" TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}" Margin="0,3,0,0" />
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="{DynamicResource Settings.ExecutionKey}" Margin="0,14,0,4" FontWeight="SemiBold" />
                                <ComboBox ItemsSource="{Binding ExecutionKeyOptions}" DisplayMemberPath="Label" SelectedValuePath="Value"
                                          AutomationProperties.Name="{DynamicResource Settings.ExecutionKey}"
                                          SelectedValue="{Binding ExecutionKeyMode}" HorizontalAlignment="Stretch" />
                                <TextBlock Text="{DynamicResource Settings.Theme}" Margin="0,14,0,4" FontWeight="SemiBold" />
                                <ComboBox ItemsSource="{Binding ThemeOptions}" DisplayMemberPath="Label" SelectedValuePath="Value"
                                          AutomationProperties.Name="{DynamicResource Settings.Theme}"
                                          SelectedValue="{Binding ThemeMode}" HorizontalAlignment="Stretch" />
                                <TextBlock Text="{DynamicResource Settings.Language}" Margin="0,14,0,4" FontWeight="SemiBold" />
                                <ComboBox ItemsSource="{Binding LanguageOptions}" DisplayMemberPath="Label" SelectedValuePath="Value"
                                          AutomationProperties.Name="{DynamicResource Settings.Language}"
                                          SelectedValue="{Binding LanguageMode}" HorizontalAlignment="Stretch" />
                                <Border Background="{DynamicResource InputBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="7" Padding="11" Margin="0,16,0,0">
                                    <TextBlock Text="{DynamicResource Settings.Security}" TextWrapping="Wrap" Foreground="{DynamicResource ErrorBrush}" />
                                </Border>
                            </StackPanel>
                        </TabItem>
                    </TabControl>
                </DockPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="12,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Ellipse Width="6" Height="6" VerticalAlignment="Center" Margin="0,0,7,0" ToolTip="{Binding Status}">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{DynamicResource MutedBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsWorkerConnected}" Value="True">
                                    <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Grid.Column="1" Text="{Binding Status}" Foreground="{DynamicResource ForegroundBrush}" FontSize="11.5" VerticalAlignment="Center" />
                <TextBlock Grid.Column="2" Text="{Binding SessionStatus}" Margin="16,0" Foreground="{DynamicResource MutedBrush}" FontSize="11.5" VerticalAlignment="Center" />
                <TextBlock Grid.Column="3" Text="{Binding DiagnosticStatus}" ToolTip="{Binding DiagnosticDetails}"
                           ToolTipService.InitialShowDelay="250" ToolTipService.ShowDuration="20000"
                           FontSize="11.5" VerticalAlignment="Center" Margin="0,0,18,0"
                           MouseLeftButtonUp="DiagnosticStatus_MouseLeftButtonUp">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource MutedBrush}" />
                            <Setter Property="Cursor" Value="Arrow" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasNavigableDiagnostics}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                    <Setter Property="Cursor" Value="Hand" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Grid.Column="4" Text="{Binding CursorStatus}" Foreground="{DynamicResource MutedBrush}" FontSize="11.5" VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</Window>
